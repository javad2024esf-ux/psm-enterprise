{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildpacks": []
  },
  "deploy": {
    "startCommand": "node /app/start.js",
    "restartPolicy": "on-failure",
    "numReplicas": 1,
    "healthchecks": {
      "liveness": {
        "command": ["CMD", "curl", "-f", "http://localhost:${PORT:-3000}/health"],
        "interval": 30,
        "timeout": 10,
        "initialDelay": 30,
        "failureThreshold": 3
      }
    }
  },
  "variables": {
    "ASPNETCORE_ENVIRONMENT": "Production",
    "ASPNETCORE_URLS": "http://+:${PORT:-3000}",
    "NODE_ENV": "production",
    "JWT_EXPIRES_IN": "24h",
    "AI_ENABLED": "true",
    "AI_MODEL": "claude-sonnet-4-6"
  }
}
