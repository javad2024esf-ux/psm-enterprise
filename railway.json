{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "docker compose build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "docker compose up",
    "restartPolicy": "always"
  },
  "volumes": [
    {
      "name": "postgres-data",
      "path": "/var/lib/postgresql/data",
      "size": 5
    }
  ]
}
