# PSM Enterprise - Security Hardened Configuration
# 
# Production Deployment Security Checklist:
# ✓ All secrets must be set via environment variables or secrets manager
# ✓ Never commit real secrets to version control
# ✓ Use strong random values (minimum 32 characters for JWT_SECRET)
# ✓ Rotate secrets regularly
# ✓ Enable HTTPS in production
# ✓ Use secure cookies with SameSite=Strict
# ✓ Keep all dependencies updated

# ─── Core Application ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT Authentication (REQUIRED) ──────────────────────────────────────────
# Generate using: openssl rand -hex 32
# Minimum 32 characters with mixed character types
JWT_SECRET=your-super-secure-random-secret-minimum-32-chars-abc123XYZ!@#$%^&*
JWT_EXPIRES_IN=24h

# ─── CSRF Protection (Auto-generated by middleware) ──────────────────────────
# No manual configuration needed - middleware generates and validates tokens

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Production: use specific domain only
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=psm_production
PG_USER=psm_user
PG_PASSWORD=secure-random-password-here
PG_SSL=true

# ─── API Security ───────────────────────────────────────────────────────────
# Rate limiting is enabled by default
# Max requests per minute per IP
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# ─── External API Keys (Optional) ───────────────────────────────────────────
# Only set if using AI features
AI_ENABLED=false
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─── License Secret (Optional) ──────────────────────────────────────────────
# Required for license validation
PSM_LICENSE_SECRET=your-license-secret-here

# ─── Logging & Monitoring ───────────────────────────────────────────────────
LOG_LEVEL=info
# Never log sensitive data like passwords, tokens, API keys
# The application automatically redacts sensitive fields

# ─── Security Headers (Configured by middleware) ────────────────────────────
# X-Content-Type-Options: nosniff
# X-Frame-Options: DENY
# X-XSS-Protection: 1; mode=block
# Strict-Transport-Security: max-age=31536000; includeSubDomains
# Content-Security-Policy: Strict CSP enabled
# Referrer-Policy: strict-origin-when-cross-origin

# ─── Cookie Security Settings ───────────────────────────────────────────────
# All cookies use:
# - HttpOnly (inaccessible to JavaScript)
# - Secure (HTTPS only)
# - SameSite=Strict (CSRF protection)

# ─── TLS/HTTPS (Production) ─────────────────────────────────────────────────
# Required for production
# Configure via reverse proxy (Nginx, Apache) or load balancer
# Certificate: Use Let's Encrypt or commercial CA
# Minimum TLS version: 1.2
# Ciphers: Prefer modern, secure suites only

# ─── Data Protection ────────────────────────────────────────────────────────
DATA_DIR=./data
# Ensure proper file permissions: 700 for directories, 600 for files
# Backup location must be encrypted at rest

# ─── Development Only ──────────────────────────────────────────────────────
# Never set these in production
# DEBUG=false
# SWAGGER_ENABLED=false  # Swagger disabled in production
