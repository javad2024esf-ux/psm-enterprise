# ═════════════════════════════════════════════════════════════════════════════
# PSM Enterprise - Docker Compose Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: This file contains sensitive configuration.
# - Never commit to version control
# - Never share the JWT_SECRET with others
# - In production, use a proper secrets manager (HashiCorp Vault, AWS Secrets Manager, etc.)
#

# ─── Core Application ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=psm-enterprise
PORT=3000
FRONTEND_PORT=80

# ─── JWT Authentication (CRITICAL - REQUIRED) ────────────────────────────────
# Generated: openssl rand -hex 32 -> base64 encoded + random suffix for strength
# This MUST be at least 32 characters and include mixed character types
# CHANGE THIS VALUE IN PRODUCTION
JWT_SECRET=aY7kL9pQmZ3xR2wN4sB1cD5eF8gH6jK0PoL2MqR5tU8vX9yZ3aB6cD9eF2gH5jK8
JWT_EXPIRES_IN=24h

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Docker Compose will use these credentials
PG_HOST=db
PG_PORT=5432
PG_DATABASE=psm
PG_USER=psm_user
PG_PASSWORD=secure_psm_password_2026_change_in_production
PG_PORT_EXTERNAL=5433
PG_SSL=false

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Local development - includes common local development origins
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:80,http://127.0.0.1:3000

# ─── Admin Seed Credentials ──────────────────────────────────────────────────
# Used for database seeding - create default admin user
# CHANGE THESE IMMEDIATELY AFTER FIRST LOGIN
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=Admin@PSM#2026

# ─── License & Security ─────────────────────────────────────────────────────
# PSM Enterprise license secret
PSM_LICENSE_SECRET=license_secret_2024_psm_enterprise_v9

# ─── AI Integration (Optional) ───────────────────────────────────────────────
# Anthropic Claude API for AI features in HAZOP, LOPA, BowTie, etc.
# Leave empty to disable AI features
AI_ENABLED=false
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
